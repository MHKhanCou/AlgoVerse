# ========================================
# AlgoVerse Environment Configuration
# ========================================
# Copy this to .env and fill in real values:
#   cp .env.example .env

# Environment: development | production
ENVIRONMENT=development

# ---------- Development ----------
DEV_DATABASE_URL=sqlite:///./algoverse.db
DEV_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
DEV_FRONTEND_URL=http://localhost:5173
DEV_BACKEND_URL=http://localhost:8000

# ---------- Production ----------
# Format: postgresql://user:password@host:port/dbname
PROD_DATABASE_URL=
PROD_CORS_ORIGINS=https://your-frontend.vercel.app
PROD_FRONTEND_URL=https://your-frontend.vercel.app
PROD_BACKEND_URL=https://your-backend.onrender.com

# ---------- JWT ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ---------- Email (Gmail App Password) ----------
# 1. Enable 2FA on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
DISABLE_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=AlgoVerse <your-email@gmail.com>

# ---------- Security ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
BCRYPT_ROUNDS=12

# ---------- App Settings ----------
DEBUG=true
AUTO_CREATE_TABLES=false
BASE_URL=http://localhost:8000
